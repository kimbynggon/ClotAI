# ================================================================
#  ClotAI 백엔드 환경 변수 예시
#  .env 파일을 복사해서 실제 값을 채워주세요
# ================================================================

# ── 서버 ─────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── 데이터베이스 (PostgreSQL) ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clotai
DB_USER=postgres
DB_PASSWORD=

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3001
