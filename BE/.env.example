# ================================================================
#  ClotAI 백엔드 환경 변수 예시
#  .env 파일을 복사해서 실제 값을 채워주세요
# ================================================================

# ── 서버 ─────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── 데이터베이스 (Prisma 연결 문자열) ─────────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/clotai

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3001

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_change_this_in_production
JWT_EXPIRES_IN=7d

# ── AI 서비스 ─────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
