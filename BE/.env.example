# ================================================================
#  ClotAI 백엔드 환경 변수 예시
#  .env 파일을 복사해서 실제 값을 채워주세요
# ================================================================

# ── 서버 ─────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── 데이터베이스 (Prisma 연결 문자열) ─────────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/clotai

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3001

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_change_this_in_production
JWT_EXPIRES_IN=7d

# ── AI 서비스 ─────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000

# ── 소셜 로그인 ───────────────────────────────────────────────────
# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Kakao OAuth (developers.kakao.com)
KAKAO_DEFAULT_REST_API_KEY=your_kakao_rest_api_key
KAKAO_DEFAULT_JS_KEY=your_kakao_js_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_CALLBACK_URL=http://localhost:3000/api/auth/kakao/callback

# ── 프론트엔드 URL ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001
