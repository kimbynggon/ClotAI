# ================================================================
#  ClotAI 백엔드 환경 변수 예시
#  .env 파일을 복사해서 실제 값을 채워주세요
# ================================================================

# ── 서버 ─────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── 데이터베이스 (PostgreSQL) ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clotai
DB_USER=postgres
DB_PASSWORD=852456

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3001

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_change_this_in_production
JWT_EXPIRES_IN=7d

# ── 이메일 인증 ──────────────────────────────────────────────────
# true: 회원가입 시 이메일 인증 필요 / false: 즉시 가입
EMAIL_VERIFICATION_ENABLED=false

# ── SMTP (EMAIL_VERIFICATION_ENABLED=true 시 필요) ────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@clotai.com
