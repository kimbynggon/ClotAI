# ================================================================
#  ClotAI AI 서비스 환경 변수 예시
# ================================================================

# ── Google Gemini ─────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here

# ── 모델 설정 ────────────────────────────────────────────────────
AI_MODEL=gemini-1.5-flash

# ── 서버 ─────────────────────────────────────────────────────────
PORT=8000

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
