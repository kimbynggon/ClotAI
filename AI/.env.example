# ================================================================
#  ClotAI AI 서비스 환경 변수 예시
# ================================================================

# ── OpenRouter ───────────────────────────────────────────────────
# openrouter.ai → Keys 에서 발급 (sk-or-v1-... 형식)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── 모델 설정 ────────────────────────────────────────────────────
# 폴백 체인 순서: gemma-3-27b(메인) → llama-3.3(백업) → llama-3.1-8b-free → llama-3.1-8b(유료)
# 1순위: google/gemma-3-27b-it:free              — 고품질, 현재 무료 안정
# 2순위: meta-llama/llama-3.3-70b-instruct:free  — GPT-4급, 무료
# 3순위: meta-llama/llama-3.1-8b-instruct:free   — 경량 무료
# 4순위: meta-llama/llama-3.1-8b-instruct        — 유료 최후 보루
# ※ qwen/qwen3-14b:free 는 2026-06 무료 지원 종료로 제거
AI_MODEL=google/gemma-3-27b-it:free

# ── 서버 ─────────────────────────────────────────────────────────
PORT=8000
# Render 등 컨테이너 환경에서 로그가 안 보일 경우 반드시 설정
PYTHONUNBUFFERED=1

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
