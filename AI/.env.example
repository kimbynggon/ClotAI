# ================================================================
#  ClotAI AI 서비스 환경 변수 예시
# ================================================================

# ── OpenRouter ───────────────────────────────────────────────────
# openrouter.ai → Keys 에서 발급 (sk-or-v1-... 형식)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── 모델 설정 ────────────────────────────────────────────────────
# 기본값 (무료 티어 권장):
#   meta-llama/llama-3.3-70b-instruct:free  — 기본 권장 (GPT-4급 성능)
#   meta-llama/llama-3.1-8b-instruct:free   — 경량 폴백
AI_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── 서버 ─────────────────────────────────────────────────────────
PORT=8000
# Render 등 컨테이너 환경에서 로그가 안 보일 경우 반드시 설정
PYTHONUNBUFFERED=1

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
