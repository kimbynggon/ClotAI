# ================================================================
#  ClotAI AI 서비스 환경 변수 예시
# ================================================================

# ── Groq (1순위 — 무료, 빠름) ─────────────────────────────────────
# console.groq.com → API Keys 에서 발급 (gsk_... 형식)
# 모델: llama-3.3-70b-versatile → llama-3.1-8b-instant 순으로 폴백
GROQ_API_KEY=gsk_your-groq-key-here

# ── OpenRouter (2순위 폴백) ───────────────────────────────────────
# openrouter.ai → Keys 에서 발급 (sk-or-v1-... 형식)
# ※ 2026-06 기준 무료 모델 대부분 유료 전환됨 — Groq 우선 사용 권장
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── 서버 ─────────────────────────────────────────────────────────
PORT=8000
# Render 등 컨테이너 환경에서 로그가 안 보일 경우 반드시 설정
PYTHONUNBUFFERED=1

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
