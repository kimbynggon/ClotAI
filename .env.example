# ================================================================
#  ClotAI 통합 환경 변수 템플릿
#
#  이 파일을 .env 로 복사 후 값 채우기:
#    cp .env.example .env
#
#  그 후 분리 스크립트 실행:
#    node setup-env.js
#
#  → BE/.env 와 FE/.env.local 이 자동 생성됩니다.
# ================================================================

# ════════════════════════════════════════
#  [BE] 백엔드 (Node.js / Express)
# ════════════════════════════════════════

BE_PORT=3000
BE_NODE_ENV=development

BE_DB_HOST=localhost
BE_DB_PORT=5432
BE_DB_NAME=clotai
BE_DB_USER=postgres
BE_DB_PASSWORD=your_db_password

BE_CORS_ORIGIN=http://localhost:3001

BE_JWT_SECRET=your_jwt_secret_change_this_in_production
BE_JWT_EXPIRES_IN=7d

# true: 회원가입 시 이메일 인증 필요 / false: 즉시 가입
BE_EMAIL_VERIFICATION_ENABLED=false

# SMTP (이메일 인증 활성화 시)
# BE_SMTP_HOST=smtp.gmail.com
# BE_SMTP_PORT=587
# BE_SMTP_USER=
# BE_SMTP_PASS=
# BE_SMTP_FROM=noreply@clotai.com

# ════════════════════════════════════════
#  [FE] 프론트엔드 (Next.js)
# ════════════════════════════════════════

FE_NEXT_PUBLIC_API_URL=http://localhost:3000
# true=목업(백엔드 불필요), false=실제 API
FE_NEXT_PUBLIC_USE_MOCK=false
# true=이메일 인증 활성화, false=즉시 가입 (BE 설정과 일치)
FE_NEXT_PUBLIC_ENABLE_EMAIL_VERIFICATION=false

# ════════════════════════════════════════
#  [AI] AI 서비스 (Python / FastAPI)
# ════════════════════════════════════════

AI_PORT=8000
AI_NODE_ENV=development

# DB (BE와 동일한 DB 공유)
AI_DB_HOST=localhost
AI_DB_PORT=5432
AI_DB_NAME=clotai
AI_DB_USER=postgres
AI_DB_PASSWORD=your_db_password

AI_CORS_ORIGIN=http://localhost:3001

# OpenAI / AI 모델 (추후)
# AI_OPENAI_API_KEY=
# AI_MODEL_NAME=gpt-4o
