meta {
  name: 프로필 등록/수정
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/profile
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "gender": "male",
    "birthYear": 1998,
    "height": 178.5,
    "weight": 70.0,
    "bodyType": "rectangle",
    "styleTags": ["casual", "minimal"],
    "colorTags": ["black", "white", "navy"],
    "budgetTier": "mid"
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.gender: eq male
}
