# ================================================================
#  ClotAI 프론트엔드 환경 변수 템플릿
#  cp .env.local.example .env.local 후 값 채우기
# ================================================================

NEXT_PUBLIC_API_URL=http://localhost:3000

# false: 실제 API 사용 (권장) / true: 목업 모드 (백엔드 없이 테스트)
NEXT_PUBLIC_USE_MOCK=false

# BE의 EMAIL_VERIFICATION_ENABLED 와 동일하게 설정
NEXT_PUBLIC_ENABLE_EMAIL_VERIFICATION=false
