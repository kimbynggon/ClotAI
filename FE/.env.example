# ================================================================
#  ClotAI 프론트엔드 환경 변수 예시
#  .env.local 파일을 생성해서 실제 값을 채워주세요
# ================================================================

# ── API 서버 ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000

# ── Mock API (true: 백엔드 없이 개발, false: 실제 API 사용) ───────
NEXT_PUBLIC_USE_MOCK=false

# ── 이메일 인증 활성화 여부 ────────────────────────────────────────
# true로 설정 시 회원가입에 이메일 인증 단계 추가
NEXT_PUBLIC_ENABLE_EMAIL_VERIFICATION=false
