# ================================================================
#  Claude Code 컨텍스트 제외 규칙
#  Claude가 읽지 않을 파일/폴더 목록
# ================================================================

# ── 이미지 파일 ─────────────────────────────────────────────────
*.jpg
*.jpeg
*.png
*.webp
*.gif
*.svg
*.ico
*.bmp
*.tiff
*.avif

# ── 업로드 폴더 (사용자 이미지) ──────────────────────────────────
uploads/

# ── 의존성 ──────────────────────────────────────────────────────
node_modules/
**/node_modules/
__pycache__/
**/__pycache__/
*.pyc
*.pyo

# ── 빌드 결과물 ─────────────────────────────────────────────────
dist/
.next/
build/
*.js.map
*.d.ts.map

# ── Lock 파일 (대용량 / 읽어도 의미 없음) ─────────────────────────
package-lock.json
yarn.lock
pnpm-lock.yaml

# ── 환경변수 (실제 값 노출 방지) ─────────────────────────────────
.env
.env.local
.env.*.local

# ── 로그 ─────────────────────────────────────────────────────────
log/
*.log
*.err

# ── 폰트 / 미디어 ────────────────────────────────────────────────
*.woff
*.woff2
*.ttf
*.eot
*.mp4
*.mp3
*.pdf
